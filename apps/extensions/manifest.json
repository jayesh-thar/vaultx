{
  "manifest_version": 3,
  "name": "VaultX",
  "version": "1.0.0",
  "description": "Zero-knowledge encrypted password manager",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle",
      "exclude_matches": ["http://localhost/*", "https://localhost/*"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://vaultx-api.onrender.com/*",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "vaultx@extension",
      "strict_min_version": "109.0"
    }
  }
}
